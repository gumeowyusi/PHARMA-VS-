# =============================================
#  HƯỚNG DẪN: Copy file này thành
#  application-secret.properties
#  rồi điền giá trị thật vào
# =============================================

# Database
DB_PASSWORD=your_db_password

# Gmail App Password (tạo tại myaccount.google.com > Security > App passwords)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# PayOS (lấy tại my.payos.vn > Kênh thanh toán > Thông tin tích hợp)
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key_64chars

# Gemini AI (lấy tại aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL_ID=gemini-1.5-flash

# ─────────────────────────────────────────────────
# OAuth2 – Google
# 1. Vào: console.cloud.google.com
# 2. APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized JavaScript origins: http://localhost:8080
# 5. Authorized redirect URIs: http://localhost:8080/login/oauth2/code/google
# ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ─────────────────────────────────────────────────
# OAuth2 – Facebook
# 1. Vào: developers.facebook.com > My Apps > Create App
# 2. Chọn loại: Consumer (hoặc Business)
# 3. Add Product > Facebook Login > Settings
# 4. Valid OAuth Redirect URIs: http://localhost:8080/login/oauth2/code/facebook
# 5. Permissions: email, public_profile
# 6. Lấy App ID và App Secret tại: Settings > Basic
# LƯU Ý: App phải ở chế độ Live (không phải Development) để user bên ngoài đăng nhập được
#        Hoặc thêm tester account tại App Roles > Roles nếu vẫn ở Development mode
# ─────────────────────────────────────────────────
FACEBOOK_CLIENT_ID=YOUR_FACEBOOK_APP_ID
FACEBOOK_CLIENT_SECRET=YOUR_FACEBOOK_APP_SECRET
